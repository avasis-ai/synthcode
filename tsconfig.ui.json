{
  "compilerOptions": {
    "strict": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "noImplicitAny": false
  },
  "include": ["src/ui/**/*.tsx", "src/ui/**/*.ts"]
}
