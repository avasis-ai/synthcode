import {
  Message,
  UserMessage,
  AssistantMessage,
  ToolResultMessage,
  ContentBlock,
  TextBlock,
  ToolUseBlock,
  ThinkingBlock,
} from "./types";

export type FlowControlType = "sequential" | "conditional" | "loop";

export interface GraphNode {
  id: string;
  type: "user" | "assistant" | "tool";
  content: ContentBlock[];
  flowControl?: {
    type: FlowControlType;
    details: Record<string, any>;
  };
}

export interface DependencyGraph {
  nodes: GraphNode[];
  edges: {
    from: string;
    to: string;
    label?: string;
  }[];
}

export class ToolCallDependencyGraphVisualizer {
  private graph: DependencyGraph;

  constructor(graph: DependencyGraph) {
    this.graph = graph;
  }

  private getNodeLabel(node: GraphNode): string {
    if (node.type === "user") {
      return `User Input: ${node.content.map((block) => block.type === "text" ? (block as TextBlock).text.substring(0, 20) + "..." : "").join(" | ")}`;
    }
    if (node.type === "assistant") {
      const toolUses = (node.content as any[]).filter((block) => block.type === "tool_use") as ToolUseBlock[];
      if (toolUses.length > 0) {
        return `Assistant Calls: ${toolUses.map((t) => t.name).join(", ")}`;
      }
      return `Assistant Response`;
    }
    if (node.type === "tool") {
      return `Tool Result (${node.id.substring(0, 4)}...)`;
    }
    return `Unknown Node`;
  }

  private renderFlowControl(node: GraphNode): string {
    if (!node.flowControl) {
      return "";
    }

    const { type, details } = node.flowControl;
    let mermaidSyntax = "";

    switch (type) {
      case "conditional":
        const conditions = Object.entries(details).map(([key, value]) => {
          const result = typeof value === 'string' ? value : 'true';
          return `${key} ? ${result} : ${key} ? ${result} : default`;
        }).join(" & ");
        mermaidSyntax = `if ${conditions} { ... } else { ... }`;
        break;
      case "loop":
        mermaidSyntax = `loop { ... }`;
        break;
      default:
          return "";
    }
    return `\nsubgraph Flow Control (${type.toUpperCase()})\n${mermaidSyntax}\nend\n`;
  }

  private renderNode(node: GraphNode): string {
    let contentSummary = "";
    if (node.content.length > 0) {
      const textBlocks = (node.content as TextBlock[]).filter(b => b.type === "text");
      if (textBlocks.length > 0) {
        contentSummary += `Text: ${textBlocks[0].text.substring(0, 30)}...`;
      }
      const toolUses = (node.content as ToolUseBlock[]).filter(b => b.type === "tool_use");
      if (toolUses.length > 0) {
        contentSummary += ` | Tools: ${toolUses.map(t => t.name).join(", ")}`;
      }
    }

    let nodeDefinition = `A${node.type.charAt(0).toUpperCase()}${node.type.slice(1)}_${node.id.replace(/[^a-zA-Z0-9]/g, '')}["${node.getNodeLabel(node)}"]`;

    if (node.flowControl) {
      nodeDefinition += this.renderFlowControl(node);
    }

    return nodeDefinition;
  }

  private renderEdges(edges: { from: string; to: string; label?: string }[]): string {
    return edges.map((edge) => {
      let edgeSyntax = `${edge.from} --> ${edge.to}`;
      if (edge.label) {
        edgeSyntax += `\n${edge.from} -->|${edge.label}| ${edge.to}`;
      }
      return edgeSyntax;
    }).join("\n");
  }

  public renderMermaidDiagram(): string {
    let mermaid = "graph TD\n";

    // 1. Render Nodes
    const nodeDeclarations = this.graph.nodes.map(this.renderNode).join("\n");
    mermaid += "\n%% --- Nodes ---\n" + nodeDeclarations + "\n";

    // 2. Render Edges
    const edgeDeclarations = this.renderEdges(this.graph.edges);
    mermaid += "\n%% --- Edges ---\n" + edgeDeclarations + "\n";

    return mermaid;
  }
}