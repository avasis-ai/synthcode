{
  "name": "@avasis-ai/synthcode",
  "version": "1.1.1",
  "description": "SynthCode - Synthesize any LLM into a production-grade AI agent. Battle-tested agentic patterns, model-agnostic, TypeScript-first.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./llm": {
      "import": {
        "types": "./dist/llm/index.d.ts",
        "default": "./dist/llm/index.js"
      },
      "require": {
        "types": "./dist/llm/index.d.cts",
        "default": "./dist/llm/index.cjs"
      }
    },
    "./tools": {
      "import": {
        "types": "./dist/tools/index.d.ts",
        "default": "./dist/tools/index.js"
      },
      "require": {
        "types": "./dist/tools/index.d.cts",
        "default": "./dist/tools/index.cjs"
      }
    },
    "./memory": {
      "import": {
        "types": "./dist/memory/index.d.ts",
        "default": "./dist/memory/index.js"
      },
      "require": {
        "types": "./dist/memory/index.d.cts",
        "default": "./dist/memory/index.cjs"
      }
    },
    "./mcp": {
      "import": {
        "types": "./dist/mcp/index.d.ts",
        "default": "./dist/mcp/index.js"
      },
      "require": {
        "types": "./dist/mcp/index.d.cts",
        "default": "./dist/mcp/index.cjs"
      }
    },
    "./tools/fuzzy-edit": {
      "import": {
        "types": "./dist/tools/fuzzy-edit.d.ts",
        "default": "./dist/tools/fuzzy-edit.js"
      },
      "require": {
        "types": "./dist/tools/fuzzy-edit.d.cts",
        "default": "./dist/tools/fuzzy-edit.cjs"
      }
    },
    "./verify": {
      "import": {
        "types": "./dist/verify/index.d.ts",
        "default": "./dist/verify/index.js"
      },
      "require": {
        "types": "./dist/verify/index.d.cts",
        "default": "./dist/verify/index.cjs"
      }
    },
    "./model-registry": {
      "import": {
        "types": "./dist/model/index.d.ts",
        "default": "./dist/model/index.js"
      },
      "require": {
        "types": "./dist/model/index.d.cts",
        "default": "./dist/model/index.cjs"
      }
    }
  },
  "bin": {
    "synthcode": "dist/cli/run.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src/",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "ink": "^7.0.0",
    "openai": "^4.70.0",
    "react": "^19.2.5",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "ink": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "openai": "^4.78.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0",
    "zod": "^3.24.0"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "agentic",
    "claude",
    "claude-code",
    "gpt",
    "tool-use",
    "mcp",
    "context-management",
    "synthcode",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avasis-ai/synthcode.git"
  },
  "homepage": "https://github.com/avasis-ai/synthcode#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
